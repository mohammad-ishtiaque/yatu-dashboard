# Copy this to .env.local and fill in real values
# .env.local is gitignored — NEVER commit real secrets

# Your backend API base URL
# In dev: your local backend (e.g. http://localhost:8000)
# In prod: your AWS ALB or API Gateway URL
VITE_API_URL=http://localhost:8000/api/v1

# Optional: turn on React Query devtools
VITE_ENABLE_DEVTOOLS=true
